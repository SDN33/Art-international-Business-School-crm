    {
      "parameters": {
        "jsCode": "const invData = $('Aplatir invités 24h').item.json;\nconst contact = Array.isArray($json) ? $json[0] : $json;\nif (!contact?.id) return [];\n\nconst phones = Array.isArray(contact.phone_jsonb) ? contact.phone_jsonb : [];\nconst phone = phones[0]?.number || '';\n\n// Anti-doublon via static data\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.reminded24h) staticData.reminded24h = {};\nconst today = new Date().toISOString().slice(0,10);\nconst key = invData.event_uuid + '_' + today;\nif (staticData.reminded24h[key]) return [];\n\nconst dt = new Date(invData.start_time);\n// Date/heure Paris (UTC+2 en été)\nconst pDate = new Date(dt.getTime() + 2*60*60*1000);\nconst dayNames = ['dimanche','lundi','mardi','mercredi','jeudi','vendredi','samedi'];\nconst monthNames = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];\nconst dayStr = `${dayNames[pDate.getUTCDay()]} ${pDate.getUTCDate()} ${monthNames[pDate.getUTCMonth()]}`;\nconst timeStr = String(pDate.getUTCHours()).padStart(2,'0') + 'h' + String(pDate.getUTCMinutes()).padStart(2,'0');\nconst firstName = (invData.invitee_name || '').split(' ')[0] || 'vous';\nconst joinUrl = invData.join_url || 'https://calendly.com/caroline-art-aibs/30min';\n\nconst message = `Bonjour ${firstName} ! 📅\\n\\nPetit rappel : votre diagnostic de carrière artistique avec l'AIBS est prévu *demain ${dayStr} à ${timeStr}*.\\n\\nLien de connexion :\\n${joinUrl}\\n\\nÀ demain ! 🎨`;\n\nreturn [{\n  json: {\n    ...invData,\n    contact_id: contact.id,\n    phone,\n    message,\n    dedup_key: key,\n    time_str: timeStr,\n    day_str: dayStr\n  }\n}];"
      },
