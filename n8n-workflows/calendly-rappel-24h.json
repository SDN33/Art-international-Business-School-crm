      "parameters": {
        "jsCode": "const d = $('Préparer rappel 24h').item.json;\nconst firstName = (d.invitee_name || '').split(' ')[0] || 'vous';\nconst email = d.invitee_email || '';\nif (!email) return [];\nconst joinUrl = d.join_url || 'https://calendly.com/caroline-art-aibs/30min';\nconst timeStr = d.time_str || '';\nconst dayStr = d.day_str || 'demain';\nconst subject = `📅 Rappel : votre visio AIBS demain (${dayStr} à ${timeStr})`;\nconst html = `<div style='font-family:Arial,sans-serif;max-width:600px;margin:0 auto'>\n  <div style='background:#1a1a2e;padding:20px;text-align:center'>\n    <h2 style='color:#fff;margin:0'>🎨 AIBS — Rappel J-1</h2>\n  </div>\n  <div style='padding:30px'>\n    <p>Bonjour ${firstName},</p>\n    <p>Petit rappel amical : votre <strong>diagnostic de carrière artistique</strong> avec l'AIBS est prévu <strong>demain ${dayStr} à ${timeStr}</strong>.</p>\n    <p style='text-align:center;margin:30px 0'>\n      <a href='${joinUrl}' style='background:#e94560;color:#fff;padding:14px 28px;border-radius:6px;text-decoration:none;font-weight:bold'>Rejoindre le visio</a>\n    </p>\n    <p style='color:#666;font-size:13px'>Si ce lien ne fonctionne pas, copiez-le dans votre navigateur :<br>${joinUrl}</p>\n    <p>Préparez vos questions, on a hâte d'échanger avec vous !</p>\n    <p>À demain ! 🎨<br>L'équipe AIBS</p>\n  </div>\n  <div style='background:#f5f5f5;padding:15px;text-align:center;font-size:11px;color:#999'>\n    Art International Business School — contact@artaibs.fr\n  </div>\n</div>`;\nreturn [{ json: { to: email, subject, html } }];"
      },
