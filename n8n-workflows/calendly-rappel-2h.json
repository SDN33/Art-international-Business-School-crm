      "id": "b2c3d4e5-0012-4000-8000-000000000012",
      "name": "Envoyer Email 2h",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [2220, 420]
    },
    {
      "parameters": {
        "jsCode": "// Marquer comme rappelé dans static data\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.reminded2h) staticData.reminded2h = {};\nconst key = $('Préparer rappel 2h').item.json.dedup_key;\nif (key) staticData.reminded2h[key] = Date.now();\n// Nettoyer > 3 jours\nconst cutoff = Date.now() - 3*24*60*60*1000;\nfor (const [k,v] of Object.entries(staticData.reminded2h)) {\n  if (v < cutoff) delete staticData.reminded2h[k];\n}\nreturn $input.all();"
      },
      "id": "b2c3d4e5-0010-4000-8000-000000000010",
      "name": "Marquer rappelé",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2440, 300]
    }
