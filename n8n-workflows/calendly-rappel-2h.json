        "jsCode": "const events = $json.collection || [];\nif (events.length === 0) return [];\nreturn events.map(e => ({\n  json: {\n    event_uuid: e.uri?.split('/').pop(),\n    start_time: e.start_time,\n    join_url: e.location?.join_url || e.location?.location || 'https://calendly.com/caroline-art-aibs/30min'\n  }\n}));"
