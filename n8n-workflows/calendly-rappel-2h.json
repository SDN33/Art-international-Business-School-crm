      "id": "b2c3d4e5-0009-4000-8000-000000000009",
      "name": "Envoyer rappel WA",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [2000, 200]
    },
    {
      "parameters": {
        "jsCode": "const d = $('Préparer rappel 2h').item.json;\nconst firstName = (d.invitee_name || '').split(' ')[0] || 'vous';\nconst email = d.invitee_email || '';\nif (!email) return [];\nconst joinUrl = d.join_url || 'https://calendly.com/caroline-art-aibs/30min';\nconst timeStr = d.time_str || '';\nconst subject = `⏰ Rappel : votre visio AIBS dans 2h (${timeStr})`;\nconst html = `<div style='font-family:Arial,sans-serif;max-width:600px;margin:0 auto'>\n  <h2 style='color:#1a1a2e'>Rappel — Votre diagnostic de carrière</h2>\n  <p>Bonjour ${firstName},</p>\n  <p>Votre session de diagnostic artistique avec l'AIBS commence <strong>dans 2 heures, à ${timeStr}</strong>.</p>\n  <p style='text-align:center;margin:30px 0'>\n    <a href='${joinUrl}' style='background:#e94560;color:#fff;padding:14px 28px;border-radius:6px;text-decoration:none;font-weight:bold'>Rejoindre le visio</a>\n  </p>\n  <p style='color:#666;font-size:13px'>Si ce lien ne fonctionne pas, copiez-le dans votre navigateur :<br>${joinUrl}</p>\n  <p>À tout à l'heure ! 🎨<br>L'équipe AIBS</p>\n</div>`;\nreturn [{ json: { to: email, subject, html } }];"
      },
