      "id": "b2c3d4e5-0007-4000-8000-000000000007",
      "name": "Contact Supabase 2h",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "jsCode": "const invData = $('Aplatir invités 2h').item.json;\nconst contacts = Array.isArray($json) ? $json : [];\nconst contact = contacts[0];\nif (!contact?.id) return [];\n\nconst phones = Array.isArray(contact.phone_jsonb) ? contact.phone_jsonb : [];\nconst phone = phones[0]?.number || '';\nif (!phone) return [];\n\n// Anti-doublon via notes Supabase (vérification externe non possible ici)\n// Le rappel est envoyé si le champ n8n static data ne contient pas l'uuid aujourd'hui\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.reminded2h) staticData.reminded2h = {};\n\n// Clé = event_uuid + date du jour\nconst today = new Date().toISOString().slice(0,10);\nconst key = invData.event_uuid + '_' + today;\nif (staticData.reminded2h[key]) return []; // déjà envoyé\n\nconst dt = new Date(invData.start_time);\nconst parisHour = (dt.getUTCHours() + 2) % 24;\nconst timeStr = String(parisHour).padStart(2,'0') + 'h' + String(dt.getUTCMinutes()).padStart(2,'0');\nconst firstName = (invData.invitee_name || '').split(' ')[0] || 'vous';\nconst joinUrl = invData.join_url || 'https://calendly.com/caroline-art-aibs/30min';\n\nconst message = `Bonjour ${firstName} ! ⏰\\n\\nVotre diagnostic de carrière artistique avec l'AIBS commence dans 2h, à ${timeStr}.\\n\\nLien de connexion :\\n${joinUrl}\\n\\nÀ tout à l'heure ! 🎨`;\n\nreturn [{\n  json: {\n    ...invData,\n    contact_id: contact.id,\n    phone,\n    message,\n    dedup_key: key,\n    time_str: timeStr\n  }\n}];"
      },
