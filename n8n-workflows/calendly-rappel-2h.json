      "parameters": {
        "jsCode": "const eventItem = $('Extraire events').item.json;\nconst invitees = $json.collection || [];\nreturn invitees\n  .filter(inv => inv.status === 'active' && inv.email)\n  .map(inv => ({\n    json: {\n      event_uuid: eventItem.event_uuid,\n      start_time: eventItem.start_time,\n      join_url: eventItem.join_url,\n      invitee_email: inv.email,\n      invitee_name: inv.name || ''\n    }\n  }));"
      },
